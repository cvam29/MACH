# MACH seed — environment template.
# Copy the relevant lines into the repo-root `.env` (e:\Personal\MACH\.env),
# which is gitignored, or export them in your shell. Each seed script only needs
# the vars for its own vendor and exits with a friendly message if any are absent.

# ---------- commercetools (seed:commercetools) ----------
CTP_PROJECT_KEY=
CTP_CLIENT_ID=
CTP_CLIENT_SECRET=
# Region-specific hosts (example shows europe-west1 GCP):
CTP_AUTH_URL=https://auth.europe-west1.gcp.commercetools.com
CTP_API_URL=https://api.europe-west1.gcp.commercetools.com
# Optional — defaults to manage_project:<projectKey>; space- or comma-separated.
# CTP_SCOPES=manage_project:my-project

# ---------- Algolia (seed:algolia) ----------
ALGOLIA_APP_ID=
# ADMIN key (write scope) — never ship this to the browser; the storefront uses a search-only key.
ALGOLIA_ADMIN_API_KEY=
# Optional — index names (defaults shown):
# ALGOLIA_INDEX_NAME=mach_products
# ALGOLIA_SUGGESTIONS_INDEX_NAME=mach_products_query_suggestions

# ---------- Contentstack (seed:contentstack) ----------
CONTENTSTACK_API_KEY=
CONTENTSTACK_MANAGEMENT_TOKEN=
# Delivery environment to publish to (e.g. development / production):
CONTENTSTACK_ENVIRONMENT=development
# Optional — CMA region base URL (default api.contentstack.io; EU is eu-api.contentstack.com):
# CONTENTSTACK_CMA_BASE_URL=https://api.contentstack.io
# CONTENTSTACK_LOCALE=en-us

# ---------- SQL fulfillment (seed:sql) ----------
# Option A: a full connection string (takes precedence):
# SQL_CONNECTION_STRING=Server=(localdb)\\MSSQLLocalDB;Database=Mach;Trusted_Connection=True;TrustServerCertificate=True
# Option B: discrete parts:
SQL_SERVER=(localdb)\MSSQLLocalDB
SQL_DATABASE=Mach
# Optional SQL login; omit both for Windows integrated/trusted auth:
# SQL_USER=sa
# SQL_PASSWORD=
# SQL_ENCRYPT=false
# SQL_TRUST_SERVER_CERTIFICATE=true

# ---------- seed:all ----------
# Set to true to keep running past a failing step (e.g. when only some vendors are configured).
# SEED_CONTINUE_ON_ERROR=false
