# =============================================================================
# MACH — example environment / configuration
# -----------------------------------------------------------------------------
# Copy to `.env` (and/or mirror into .NET user-secrets / local.settings.json,
# which are gitignored). NEVER commit real values.
#
# Marker legend:
#   [PUBLIC] safe to expose to the browser / ship to the client bundle
#   [SECRET] server-side only — Key Vault in prod, user-secrets locally
#
# Variable names match `docs/vendor-setup.md`. Section anchors there explain
# exactly where in each vendor portal the value is found.
# =============================================================================


# ---------------------------------------------------------------------------
# commercetools — commerce engine + customer identity
# ---------------------------------------------------------------------------
CT_PROJECT_KEY=your-project-key                         # [PUBLIC]  project key
CT_REGION=europe-west1.gcp                               # [PUBLIC]  region/provider (e.g. europe-west1.gcp)
CT_AUTH_URL=https://auth.europe-west1.gcp.commercetools.com   # [PUBLIC]  OAuth token endpoint
CT_API_URL=https://api.europe-west1.gcp.commercetools.com     # [PUBLIC]  HTTP API endpoint
CT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxx                      # [SECRET]  API client id
CT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx        # [SECRET]  API client secret
CT_SCOPES=manage_project:your-project-key               # [SECRET]  space-delimited scopes (incl. manage/view + me scopes)


# ---------------------------------------------------------------------------
# Contentstack — content + email copy
# ---------------------------------------------------------------------------
CONTENTSTACK_API_KEY=blt0000000000000000               # [PUBLIC]  stack API key
CONTENTSTACK_DELIVERY_TOKEN=cs0000000000000000000000   # [PUBLIC]  delivery (read) token
CONTENTSTACK_ENVIRONMENT=development                   # [PUBLIC]  delivery environment name
CONTENTSTACK_REGION=us                                 # [PUBLIC]  region (us / eu / azure-na / ...)
CONTENTSTACK_MANAGEMENT_TOKEN=cs0000000000000000000000 # [SECRET]  management token (seed scripts only)


# ---------------------------------------------------------------------------
# Adyen — payments (TEST)
# ---------------------------------------------------------------------------
ADYEN_CLIENT_KEY=test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX      # [PUBLIC]  Drop-in client key (browser)
ADYEN_ENVIRONMENT=test                                 # [PUBLIC]  test | live
ADYEN_MERCHANT_ACCOUNT=YourMerchantAccountECOM         # [PUBLIC]  merchant account name
ADYEN_API_KEY=AQE0000000000000000000000000000          # [SECRET]  server API key
ADYEN_HMAC_KEY=0000000000000000000000000000000000      # [SECRET]  webhook HMAC signature key
# Configure Adyen allowed origins (Customer Area) to your storefront origin,
# e.g. http://localhost:3000 — no env var, but required for the client key to work.


# ---------------------------------------------------------------------------
# Algolia — search
# ---------------------------------------------------------------------------
ALGOLIA_APP_ID=XXXXXXXXXX                               # [PUBLIC]  application id
ALGOLIA_SEARCH_KEY=00000000000000000000000000000000    # [PUBLIC]  search-only API key (browser)
ALGOLIA_INDEX_NAME=products                            # [PUBLIC]  primary index name
ALGOLIA_ADMIN_KEY=00000000000000000000000000000000     # [SECRET]  admin API key (indexer + seed only)


# ---------------------------------------------------------------------------
# Azure Maps — geocoding + distance/route matrix
# ---------------------------------------------------------------------------
AZURE_MAPS_KEY=00000000000000000000000000000000        # [SECRET]  subscription key (server-side)
# Offline alternative — no key needed: set Maps:Provider=Stub (haversine over seeded stores)
MAPS_PROVIDER=AzureMaps                                 # [PUBLIC]  AzureMaps | Stub


# ---------------------------------------------------------------------------
# Azure Communication Services (ACS) Email — transactional email
# ---------------------------------------------------------------------------
ACS_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=xxxx  # [SECRET]
ACS_SENDER_ADDRESS=DoNotReply@your-managed-domain.azurecomm.net   # [PUBLIC]  verified sender
# Offline alternative — no ACS needed: set Email:Provider=DevSink (writes .eml to ./mail/)
EMAIL_PROVIDER=DevSink                                  # [PUBLIC]  Acs | DevSink


# ---------------------------------------------------------------------------
# Notifications — multi-party fan-out recipients
# Resolved from SQL (Stores/Suppliers) at runtime; these are config fallbacks.
# ---------------------------------------------------------------------------
NOTIFICATIONS_RECIPIENT_CUSTOMER=                      # [PUBLIC]  (usually from order) fallback customer address
NOTIFICATIONS_RECIPIENT_STORE=store@example.com        # [PUBLIC]  fallback store/fulfilment address
NOTIFICATIONS_RECIPIENT_SUPPLIER=supplier@example.com  # [PUBLIC]  fallback supplier address
NOTIFICATIONS_RECIPIENT_RECEPTION=reception@example.com# [PUBLIC]  fallback goods-in / reception address


# ---------------------------------------------------------------------------
# Messaging — Azure Service Bus
# ---------------------------------------------------------------------------
MESSAGING_PROVIDER=InMemory                             # [PUBLIC]  ServiceBus | InMemory (offline)
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://your-ns.servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...  # [SECRET]
# Local emulator alternative: set MESSAGING_PROVIDER=ServiceBus and use
# Endpoint=sb://localhost;UseDevelopmentEmulator=true;...


# ---------------------------------------------------------------------------
# Storage — Azure Storage (Functions runtime + Azurite locally)
# ---------------------------------------------------------------------------
AZURE_WEBJOBS_STORAGE=UseDevelopmentStorage=true       # [SECRET]  Azurite locally; real conn string in cloud


# ---------------------------------------------------------------------------
# SQL Server — read-models / outbox / inbox / fulfillment
# ---------------------------------------------------------------------------
SQL_CONNECTION_STRING=Server=(localdb)\\MSSQLLocalDB;Database=Mach;Trusted_Connection=True;TrustServerCertificate=True  # [SECRET]


# ---------------------------------------------------------------------------
# Storefront → BFF / Auth wiring (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BFF_BASE_URL=http://localhost:7071/api     # [PUBLIC]  BFF base (APIM bypassed locally)
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:7072/api    # [PUBLIC]  Auth host base
