# Root version + provider constraints shared by every module via implicit inheritance.
# Modules do NOT re-declare provider source/version (only required_providers when they
# use a non-default provider such as azuread); the root pins the versions.
terraform {
  required_version = ">= 1.9"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
    azuread = {
      source  = "hashicorp/azuread"
      version = "~> 3.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
