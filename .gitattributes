# Normalize line endings: check out / commit with LF, auto-detect text.
# Silences the CRLF warnings on Windows checkouts.
* text=auto eol=lf

# Solution / project files are text (keep them diffable & normalized).
*.sln       text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.config    text eol=lf

# Source & docs are text.
*.cs        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.tf        text eol=lf
*.tfvars    text eol=lf
*.sql       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.env       text eol=lf

# Windows-only scripts keep CRLF; shell scripts keep LF.
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.sh        text eol=lf

# Binary assets — never normalize or diff as text.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.svg       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.zip       binary
*.gz        binary
*.7z        binary
*.dll       binary
*.exe       binary
*.snk       binary
